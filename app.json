{
  "expo": {
    "name": "nagu-organics",
    "slug": "nagu-organics",
    "scheme": "naguorganics",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
   "ios": {
  "supportsTablet": true,
  "bundleIdentifier": "com.vijayarajan1003.naguorganics",
  "googleServicesFile": "./GoogleService-Info.plist",
  "infoPlist": {
    "ITSAppUsesNonExemptEncryption": false,
    "NSLocationWhenInUseUsageDescription": "We use your location to calculate distance to Nagu Organics Store."
  }
},
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.example.naguorg",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a2138034-fe6c-4c9d-9f5f-dec44db9e4fc"
      }
    }
  }
}
